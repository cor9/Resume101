# ─── Resume101 Environment Variables ──────────────────────────────────────────
# Copy this file to .env.local for local dev, or add directly in Vercel Dashboard
# → Project → Settings → Environment Variables

# ─── MailerLite ───────────────────────────────────────────────────────────────
# Get from: MailerLite Dashboard → Integrations → API
MAILERLITE_API_KEY=

# Get from: MailerLite → Subscribers → Groups → your group → ID in the URL
MAILERLITE_GROUP_ID=

# ─── Airtable ─────────────────────────────────────────────────────────────────
# Get from: airtable.com/create/tokens (Personal Access Token)
# Scopes needed: data.records:write, schema.bases:read
AIRTABLE_API_KEY=

# Get from: Airtable base URL — airtable.com/{BASE_ID}/...
AIRTABLE_BASE_ID=

# Name of the table in your Airtable base (default: Leads)
AIRTABLE_TABLE_NAME=Leads

# ─── Anthropic (Claude Haiku — for AI chat) ───────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ─── Vercel Blob (headshot storage) ───────────────────────────────────────────
# Auto-set by Vercel when you connect a Blob store:
# Vercel Dashboard → Storage → Create → Blob → Connect to this project
BLOB_READ_WRITE_TOKEN=
